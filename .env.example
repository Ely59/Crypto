# Copy this file to .env and fill in your real values
# Never commit .env to version control

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here      # From @BotFather
TELEGRAM_CHAT_ID=your_chat_id_here          # Your personal or group chat ID

# ─── CoinMarketCap ───────────────────────────────────────────────────────────
CMC_API_KEY=your_cmc_api_key_here           # Required for Module 5 (momentum scanner)

# ─── Binance (public endpoints — no key needed, but useful for rate limits) ──
BINANCE_API_KEY=optional
BINANCE_SECRET=optional

# ─── Optional: CoinGecko Pro key (higher rate limits) ────────────────────────
COINGECKO_API_KEY=optional
